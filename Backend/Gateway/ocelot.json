{
  "Routes": [
    {
      "DownstreamPathTemplate": "/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "auth-service", "Port": 7001 } ],
      "UpstreamPathTemplate": "/auth/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post", "Put", "Delete" ],
      "SwaggerKey": "auth"
    },
    {
      "DownstreamPathTemplate": "/otp/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "auth-service", "Port": 7001 } ],
      "UpstreamPathTemplate": "/otp/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post", "Put", "Delete" ],
      "SwaggerKey": "auth"
    },
    {
      "DownstreamPathTemplate": "/posts/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "posts-service", "Port": 7003 } ],
      "UpstreamPathTemplate": "/posts/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post", "Put", "Delete" ],
      "SwaggerKey": "posts"
    }
  ],
  "SwaggerEndPoints": [
    {
      "Key": "auth",
      "Config": [ { "Name": "Auth API", "Version": "v1", "Url": "http://auth-service:7001/swagger/v1/swagger.json" } ]
    },
    {
      "Key": "posts",
      "Config": [ { "Name": "Posts API", "Version": "v1", "Url": "http://posts-service:7003/swagger/v1/swagger.json" } ]
    }
  ]
}