        <ImplicitUsings>enable</ImplicitUsings>
        <RootNamespace>AuthService</RootNamespace>
        <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
    </PropertyGroup>

    <ItemGroup>
